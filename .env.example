# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_db

# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-west1-aws
PINECONE_INDEX_NAME=rag-index

# AI Provider: "openai" or "openrouter"
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_LLM_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# OpenRouter Configuration (alternative to OpenAI)
# Get your API key from https://openrouter.ai/settings
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=google/text-embedding-004

# JWT Authentication
JWT_SECRET_KEY=your_super_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Logging
LOG_LEVEL=INFO

# Text Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_CHUNKS=5
